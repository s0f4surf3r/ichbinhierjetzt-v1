<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — ICH BIN HIER JETZT</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  <meta name="author" content="Doris R. Mumenthaler">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ title }} — ICH BIN HIER JETZT">
  <meta property="og:description" content="{{ description or 'Traumasensibles Coaching und Jin Shin Jyutsu — Doris R. Mumenthaler, Dornach' }}">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="de_CH">
  <meta property="og:site_name" content="ICH BIN HIER JETZT">
  <meta property="og:image" content="https://ichbinhierjetzt-preview.netlify.app/images/og-image.jpg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  <!-- Twitter / WhatsApp -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }} — ICH BIN HIER JETZT">
  <meta name="twitter:description" content="{{ description or 'Traumasensibles Coaching und Jin Shin Jyutsu — Doris R. Mumenthaler, Dornach' }}">
  <meta name="twitter:image" content="https://ichbinhierjetzt-preview.netlify.app/images/og-image.jpg">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet">

  <!-- Favicon -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">

  <link rel="stylesheet" href="/css/style.css">
  <script>
    // Theme sofort setzen um Flash zu vermeiden
    (function(){
      var t = localStorage.getItem('theme');
      if (t) document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body data-cms-path="{{ page.inputPath | replace('./', '') }}">
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="site-logo">ICH BIN HIER JETZT</a>
      <div class="theme-switcher" aria-label="Farbpalette wählen">
        <button class="theme-dot theme-dot--licht active" onclick="setTheme('')" title="Ecru / Rose / Sky"></button>
        <button class="theme-dot theme-dot--rose" onclick="setTheme('rose')" title="Rose / Terra"></button>
        <button class="theme-dot theme-dot--nacht" onclick="setTheme('nacht')" title="Flieder / Nacht"></button>
      </div>
      <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-label="Navigation öffnen">
      <label for="nav-toggle" class="nav-toggle-label">
        <span></span>
        <span></span>
        <span></span>
      </label>
      <nav class="main-nav">
        <a href="/" {% if page.url == "/" %}class="active"{% endif %}>Willkommen</a>
        <a href="/coaching/" {% if page.url == "/coaching/" %}class="active"{% endif %}>Coaching</a>
        <a href="/jin-shin-jyutsu/" {% if page.url == "/jin-shin-jyutsu/" %}class="active"{% endif %}>Jin Shin Jyutsu</a>
        <a href="/ueber/" {% if page.url == "/ueber/" %}class="active"{% endif %}>Über mich</a>
        <a href="/kosten/" {% if page.url == "/kosten/" %}class="active"{% endif %}>Kosten</a>
        <a href="/kontakt/" {% if page.url == "/kontakt/" %}class="active"{% endif %}>Kontakt</a>
        <a href="/texte/" {% if page.url == "/texte/" %}class="active"{% endif %}>Texte</a>
        <a href="/galerie/" {% if page.url == "/galerie/" %}class="active"{% endif %}>Galerie</a>
      </nav>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <p class="footer-copyright">Alle Fotos auf dieser Webseite stammen aus meinem Archiv und unterliegen dem Copyright® von Doris R. Mumenthaler</p>
    <nav class="footer-nav">
      <a href="/impressum/">Impressum</a>
      <a href="/datenschutz/">Datenschutz</a>
    </nav>
    <p class="footer-copy">&copy; {{ "" | year }} Doris R. Mumenthaler</p>
  </footer>
  <script>
    function setTheme(name) {
      var html = document.documentElement;
      if (name) {
        html.setAttribute('data-theme', name);
        localStorage.setItem('theme', name);
      } else {
        html.removeAttribute('data-theme');
        localStorage.removeItem('theme');
      }
      // Active-Dot aktualisieren
      document.querySelectorAll('.theme-dot').forEach(function(dot) {
        dot.classList.remove('active');
      });
      var sel = name ? '.theme-dot--' + name : '.theme-dot--licht';
      var active = document.querySelector(sel);
      if (active) active.classList.add('active');
    }
    // Beim Laden den richtigen Dot aktivieren
    (function() {
      var t = localStorage.getItem('theme') || '';
      var sel = t ? '.theme-dot--' + t : '.theme-dot--licht';
      document.querySelectorAll('.theme-dot').forEach(function(d) { d.classList.remove('active'); });
      var el = document.querySelector(sel);
      if (el) el.classList.add('active');
    })();
  </script>
  <script>
  // perfectCMS — Magic Link Auto-Login
  (function() {
    var params = new URLSearchParams(window.location.search);
    var magic = params.get('magic');
    if (!magic) return;
    var API = localStorage.getItem('cms_api_url') || 'https://perfectcmstm6mdmqs-doris-cms-api.functions.fnc.fr-par.scw.cloud';
    fetch(API + '/api/login/magic', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token: magic })
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.token) {
        localStorage.setItem('cms_token', d.token);
        history.replaceState({}, '', window.location.pathname);
        location.reload();
      }
    }).catch(function() {});
  })();
  </script>
  <script>
  // perfectCMS — Inline-Edit
  (function() {
    var token = localStorage.getItem('cms_token');
    if (!token) return;
    var API = localStorage.getItem('cms_api_url') || 'https://perfectcmstm6mdmqs-doris-cms-api.functions.fnc.fr-par.scw.cloud';
    var PAGE_PATH = document.body.getAttribute('data-cms-path');
    if (!PAGE_PATH) return;
    if (!document.querySelector('[data-cms-field]')) return;

    // Edit-Button
    var btn = document.createElement('button');
    btn.textContent = '✏ Bearbeiten';
    btn.style.cssText = 'position:fixed;bottom:1.5rem;right:1.5rem;z-index:9000;background:var(--color-fire,#c9967f);color:#fff;border:none;padding:0.6rem 1.2rem;border-radius:8px;font-size:0.9rem;cursor:pointer;box-shadow:0 4px 20px rgba(0,0,0,0.3);font-family:sans-serif;';
    document.body.appendChild(btn);

    var logoutBtn = document.createElement('button');
    logoutBtn.textContent = '× Bearbeitung beenden';
    logoutBtn.style.cssText = 'position:fixed;bottom:1.5rem;right:10.5rem;z-index:9000;background:transparent;color:var(--color-mid,#999);border:1px solid rgba(150,150,150,0.35);padding:0.6rem 1.2rem;border-radius:8px;font-size:0.9rem;cursor:pointer;font-family:sans-serif;';
    logoutBtn.addEventListener('click', function() {
      localStorage.removeItem('cms_token');
      location.reload();
    });
    document.body.appendChild(logoutBtn);

    var editing = false, saveBar = null;

    btn.addEventListener('click', function() { editing ? cancel() : start(); });

    function start() {
      editing = true;
      btn.textContent = '✕ Abbrechen';
      document.querySelectorAll('[data-cms-field]').forEach(function(el) {
        el.contentEditable = 'true';
        el.style.outline = '2px dashed rgba(201,150,127,0.7)';
        el.style.borderRadius = '4px';
        el.style.padding = '2px';
      });
      saveBar = document.createElement('div');
      saveBar.style.cssText = 'position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);z-index:9001;background:#1a1816;color:#f5f0eb;padding:0.75rem 1.5rem;border-radius:12px;display:flex;gap:1rem;align-items:center;box-shadow:0 8px 30px rgba(0,0,0,0.5);font-family:sans-serif;font-size:0.9rem;';
      saveBar.innerHTML = '<span style="opacity:0.7;">Klick auf Text zum Bearbeiten</span><button id="cms-save" style="background:var(--color-fire,#c9967f);color:#fff;border:none;padding:0.5rem 1.2rem;border-radius:6px;cursor:pointer;font-size:0.9rem;">Speichern</button>';
      document.body.appendChild(saveBar);
      document.getElementById('cms-save').addEventListener('click', save);
    }

    function cancel() {
      editing = false;
      btn.textContent = '✏ Bearbeiten';
      document.querySelectorAll('[data-cms-field]').forEach(function(el) {
        el.contentEditable = 'false';
        el.style.outline = '';
        el.style.borderRadius = '';
        el.style.padding = '';
      });
      if (saveBar) { saveBar.remove(); saveBar = null; }
    }

    function save() {
      var fields = {};
      document.querySelectorAll('[data-cms-field]').forEach(function(el) {
        fields[el.getAttribute('data-cms-field')] = el.innerHTML;
      });
      var savebtn = document.getElementById('cms-save');
      savebtn.textContent = '…'; savebtn.disabled = true;
      fetch(API + '/api/inline', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify({ path: PAGE_PATH, fields: fields })
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.error) { alert('Fehler: ' + d.error); savebtn.textContent = 'Speichern'; savebtn.disabled = false; return; }
        cancel();
        var toast = document.createElement('div');
        toast.textContent = '✓ Gespeichert — Seite wird gleich aktualisiert';
        toast.style.cssText = 'position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);background:#4caf50;color:#fff;padding:0.6rem 1.5rem;border-radius:8px;z-index:9999;font-family:sans-serif;font-size:0.9rem;';
        document.body.appendChild(toast);
        setTimeout(function() { toast.remove(); }, 3000);
      })
      .catch(function() { savebtn.textContent = 'Speichern'; savebtn.disabled = false; alert('Netzwerkfehler'); });
    }
  })();
  </script>
  <script src="/js/dev-panel.js"></script>
</body>
</html>
