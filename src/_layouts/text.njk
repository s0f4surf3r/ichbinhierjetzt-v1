---
layout: base.njk
---
<style>
  .text-article { max-width: 680px; margin: 0 auto; padding: 3rem var(--gutter) 4rem; }
  .text-back { display: inline-block; font-family: var(--font-heading); font-style: italic; color: var(--color-fire); text-decoration: none; margin-bottom: 2rem; opacity: 0.8; transition: opacity 0.2s; }
  .text-back:hover { opacity: 1; }
  .text-meta { display: flex; gap: 1rem; align-items: center; margin-bottom: 1.5rem; }
  .text-type { font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-fire); opacity: 0.8; }
  .text-date { font-size: 0.85rem; color: var(--color-mid); }
  .text-title { font-family: var(--font-heading); font-weight: 400; font-style: italic; font-size: clamp(1.6rem, 4vw, 2.4rem); color: var(--color-ember); margin-bottom: 1.5rem; line-height: 1.3; }
  .text-excerpt { font-style: italic; color: var(--color-mid); line-height: 1.8; margin-bottom: 2rem; border-left: 2px solid var(--color-fire); padding-left: 1rem; opacity: 0.85; }
  .text-body { line-height: 2.1; color: var(--color-mid-dark); }
  .text-body p { margin-bottom: 1.4rem; }
  .text-ornament { text-align: center; color: var(--color-warm); opacity: 0.4; letter-spacing: 0.5em; margin: 2.5rem 0; font-size: 0.9rem; }
  .text-hero-image { margin-top: 3rem; border-radius: 8px; overflow: hidden; }
  .text-hero-image img { width: 100%; height: auto; display: block; }
</style>

<article class="text-article">
  <a href="/texte/" class="text-back">← Texte</a>
  <div class="text-meta">
    <span class="text-type">{{ type }}</span>
    <span class="text-date">{{ date | readableDate }}</span>
  </div>
  <h1 class="text-title">{{ title }}</h1>
  {% if excerpt %}<p class="text-excerpt">{{ excerpt }}</p>{% endif %}
  <div class="text-ornament">✦</div>
  <div class="text-body">{{ content | safe }}</div>
  {% if heroImage %}
  <div class="text-hero-image">
    <img src="{{ heroImage }}" alt="{{ title }}">
  </div>
  {% endif %}
</article>
